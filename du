    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // 네비게이션 탭 스위칭 로직
            const navItems = document.querySelectorAll('.nav-item');
            const sections = document.querySelectorAll('.content-section');

            navItems.forEach(item => {
                item.addEventListener('click', (e) => {
                    const targetId = e.target.getAttribute('data-target');
                    
                    navItems.forEach(nav => nav.classList.remove('active', 'bg-blue-900', 'text-white'));
                    navItems.forEach(nav => nav.classList.add('text-stone-600'));
                    e.target.classList.add('active');
                    e.target.classList.remove('text-stone-600');

                    sections.forEach(sec => {
                        sec.classList.add('hidden');
                        sec.classList.remove('block');
                    });
                    const targetSec = document.getElementById(targetId);
                    targetSec.classList.remove('hidden');
                    targetSec.classList.add('block');
                    
                    if(window.innerWidth < 768) {
                        window.scrollTo({top: 0, behavior: 'smooth'});
                    }
                });
            });

            Chart.defaults.font.family = "'Noto Sans KR', sans-serif";
            Chart.defaults.color = '#57534e';

            // Chart 1: 수주 비중 도넛 차트
            const ctxMix = document.getElementById('mixChart').getContext('2d');
            new Chart(ctxMix, {
                type: 'doughnut',
                data: {
                    labels: ['가스터빈/복합화력', '대형원전/EPC', 'SMR 주기기', '기타/LTSA/풍력'],
                    datasets: [{
                        data: [20, 28, 8, 44],
                        backgroundColor: ['#1e3a8a', '#3b82f6', '#93c5fd', '#d6d3d1'],
                        borderWidth: 0,
                        hoverOffset: 4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { position: 'bottom', labels: { boxWidth: 10, font: { size: 11 } } }
                    },
                    cutout: '65%'
                }
            });

            // Chart 2: 실적 추이 콤보 차트
            const ctxFin = document.getElementById('financialChart').getContext('2d');
            new Chart(ctxFin, {
                type: 'bar',
                data: {
                    labels: ['2024', '2025E', '2026E', '2027E'],
                    datasets: [
                        {
                            type: 'line',
                            label: '에너빌리티 OPM (%)',
                            data: [3.5, 4.5, 6.2, 8.1],
                            borderColor: '#ef4444',
                            backgroundColor: '#ef4444',
                            borderWidth: 2,
                            pointBackgroundColor: '#fff',
                            yAxisID: 'y1',
                            tension: 0.3
                        },
                        {
                            type: 'bar',
                            label: '연결 매출액 (조 원)',
                            data: [16.5, 16.8, 17.3, 18.5],
                            backgroundColor: '#1e3a8a',
                            borderRadius: 4,
                            yAxisID: 'y'
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    interaction: { mode: 'index', intersect: false },
                    plugins: {
                        legend: { position: 'top', labels: { usePointStyle: true, boxWidth: 8, font: {size: 11} } }
                    },
                    scales: {
                        y: {
                            type: 'linear', display: true, position: 'left',
                            title: { display: window.innerWidth > 768, text: '매출액 (조 원)' },
                            grid: { color: '#e5e7eb' },
                            ticks: { font: {size: 10} },
                            min: 15
                        },
                        y1: {
                            type: 'linear', display: true, position: 'right',
                            title: { display: window.innerWidth > 768, text: 'OPM (%)' },
                            grid: { drawOnChartArea: false },
                            min: 0, max: 10,
                            ticks: { font: {size: 10} }
                        },
                        x: { grid: { display: false }, ticks: { font: {size: 10} } }
                    }
                }
            });

            // Valuation 시나리오 클릭 이벤트
            const scenarioData = {
                bear: { price: "65,000", eps: "2.57T KRW", pe: "15.0x", border: "border-red-400", bg: "bg-red-50" },
                base: { price: "104,000", eps: "2.57T KRW", pe: "26.4x", border: "border-blue-600", bg: "bg-blue-50" },
                bull: { price: "145,000", eps: "3.20T KRW", pe: "35.0x", border: "border-emerald-500", bg: "bg-emerald-50" }
            };

            const scenarioCards = document.querySelectorAll('.scenario-card');
            const displayPrice = document.getElementById('display-target-price');
            const displayEps = document.getElementById('display-eps');
            const displayPe = document.getElementById('display-pe');

            scenarioCards.forEach(card => {
                card.addEventListener('click', (e) => {
                    const el = e.currentTarget;
                    const sc = el.getAttribute('data-scenario');
                    
                    scenarioCards.forEach(c => {
                        c.classList.remove('active-scenario', 'border-blue-600', 'bg-blue-50', 'border-red-400', 'bg-red-50', 'border-emerald-500', 'bg-emerald-50');
                        c.classList.add('border-stone-200', 'bg-white');
                    });
                    
                    el.classList.remove('border-stone-200', 'bg-white');
                    el.classList.add('active-scenario', scenarioData[sc].border.split('-')[0]+"-"+scenarioData[sc].border.split('-')[1]+"-"+scenarioData[sc].border.split('-')[2], scenarioData[sc].bg);
                    
                    displayPrice.innerHTML = `${scenarioData[sc].price}<span class="text-base md:text-lg font-normal ml-1">KRW</span>`;
                    displayEps.textContent = scenarioData[sc].eps;
                    displayPe.textContent = scenarioData[sc].pe;
                });
            });
        });
    </script>
</body>
</html>
