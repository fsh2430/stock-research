                    <div class="absolute -top-4 left-1/2 transform -translate-x-1/2 bg-indigo-600 text-white px-4 py-1 rounded-full text-sm font-bold shadow-md">
                        적정 가치 (Base)
                    </div>
                    <div class="flex items-center justify-between mb-4 mt-2">
                        <h3 class="text-xl font-bold text-indigo-900">Base Case</h3>
                        <span class="px-2 py-1 bg-indigo-200 text-indigo-800 text-xs font-bold rounded">Target PER 25.0x</span>
                    </div>
                    <div class="text-3xl font-black text-indigo-700 mb-4 tracking-tight">346,000원 ~ 830,000원</div>
                    <ul class="text-sm text-slate-700 space-y-3">
                        <li>• <span class="font-semibold text-indigo-900">가정:</span> 북미 증설 물량 정상 인식.</li>
                        <li>• <span class="font-semibold text-indigo-900">현가화:</span> 장기 이익 폭발을 선반영하는 장기 모멘텀 현가화 시 실질 거래 목표가는 830k 수준 형성.</li>
                    </ul>
                </div>

                <div class="bg-white rounded-xl p-6 border border-slate-200 shadow-sm h-full">
                    <div class="flex items-center justify-between mb-4">
                        <h3 class="text-lg font-bold text-rose-700">Bull Case</h3>
                        <span class="px-2 py-1 bg-rose-50 text-rose-600 text-xs font-bold rounded">낙관적 랠리</span>
                    </div>
                    <div class="text-2xl font-black text-slate-900 mb-4">1,100,000원 이상</div>
                    <ul class="text-sm text-slate-600 space-y-2">
                        <li>• <span class="font-semibold text-slate-800">가정:</span> 하니웰 S/W 플랫폼 대성공으로 IT/플랫폼 멀티플(35x+) 부여</li>
                        <li>• <span class="font-semibold text-slate-800">프리미엄:</span> 극단적 리드타임 프리미엄 발생 및 시장 오버슈팅 결합</li>
                    </ul>
                </div>

            </div>
        </div>
    </section>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // 1. Intersection Observer for slide-up animation
            const observerOptions = {
                root: null,
                rootMargin: '0px',
                threshold: 0.15
            };

            const observer = new IntersectionObserver((entries, observer) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('visible');
                        observer.unobserve(entry.target);
                    }
                });
            }, observerOptions);

            const elementsToAnimate = document.querySelectorAll('.slide-up-element');
            elementsToAnimate.forEach(el => observer.observe(el));

            // 2. Chart.js Initialization
            const ctx = document.getElementById('financialChart').getContext('2d');
            
            // 데이터 추정 (PDF 텍스트 기반 논리적 추론)
            // 매출액(단위: 십억원) : 2023(약 4550)-> 2024E(4750) -> 2025E(4960)
            // 영업이익(단위: 십억원) : 2023(약 350)-> 2024E(380) -> 2025E(426.4)
            const labels = ['2023', '2024 (E)', '2025 (E)'];
            const salesData = [4550, 4750, 4960]; 
            const opData = [350, 380, 426.4]; 

            new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: labels,
                    datasets: [
                        {
                            label: '영업이익 (십억원)',
                            type: 'line',
                            data: opData,
                            borderColor: '#e11d48', // rose-600
                            backgroundColor: '#e11d48',
                            borderWidth: 3,
                            pointBackgroundColor: '#fff',
                            pointBorderColor: '#e11d48',
                            pointRadius: 6,
                            pointHoverRadius: 8,
                            yAxisID: 'y1',
                            tension: 0.3
                        },
                        {
                            label: '매출액 (십억원)',
                            type: 'bar',
                            data: salesData,
                            backgroundColor: '#4f46e5', // indigo-600
                            borderRadius: 6,
                            barPercentage: 0.5,
                            yAxisID: 'y'
                        }
                    ]
                },
                options: {
                    responsive: true,
                    interaction: {
                        mode: 'index',
                        intersect: false,
                    },
                    plugins: {
                        legend: {
                            position: 'top',
                            labels: {
                                font: {
                                    family: "'Noto Sans KR', sans-serif"
                                },
                                usePointStyle: true
                            }
                        },
                        tooltip: {
                            titleFont: { family: "'Noto Sans KR', sans-serif" },
                            bodyFont: { family: "'Noto Sans KR', sans-serif" }
                        }
                    },
                    scales: {
                        y: {
                            type: 'linear',
                            display: true,
                            position: 'left',
                            title: {
                                display: true,
                                text: '매출액 (십억원)',
                                font: { family: "'Noto Sans KR', sans-serif", size: 12 }
                            },
                            grid: {
                                color: '#f1f5f9'
                            }
                        },
                        y1: {
                            type: 'linear',
                            display: true,
                            position: 'right',
                            title: {
                                display: true,
                                text: '영업이익 (십억원)',
                                font: { family: "'Noto Sans KR', sans-serif", size: 12 }
                            },
                            grid: {
                                drawOnChartArea: false
                            }
                        },
                        x: {
                            grid: {
                                display: false
                            },
                            ticks: {
                                font: { family: "'Noto Sans KR', sans-serif", weight: 'bold' }
                            }
                        }
                    }
                }
            });
        });
    </script>
</body>
</html>
